{
  "name": "@bestoffers/api",
  "version": "0.1.0",
  "private": true,
  "description": "BestOffers API — NestJS modular monolith (ADR-001). Auth · search-orchestrator · providers · offers · logging.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn src/main.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "db:supabase:push": "node scripts/supabase-push.mjs",
    "seed": "ts-node src/db/seed.ts",
    "live:offers": "ts-node scripts/live-offers-spike.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@bestoffers/shared": "*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.7",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@nestjs/testing": "^10.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.61.1",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
