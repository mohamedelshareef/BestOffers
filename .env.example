# =============================================================================
# BestOffers — environment template
# The app RUNS fully in dev/mock mode with NO real third-party keys:
#   OTP_PROVIDER=mock, BILLING_PROVIDER=mock, Supabase via `supabase start` (local).
# Fill real keys only to exercise live WhatsApp / Stripe / hosted Supabase.
# =============================================================================

# ── Anthropic / Claude API (https://console.anthropic.com/) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Local identity plane (mock mode — issues/verifies the access JWT when Supabase is NOT wired) ──
JWT_SECRET=dev-mock-jwt-secret-not-for-prod   # HS256 secret for the LOCAL JWT issuer (mock mode only)
STORAGE_PROVIDER=local             # local (mock disk) | supabase (config-ready)
STORAGE_DIR=                       # avatar disk root for local storage (default apps/api/.storage/avatars)

# ── Supabase: identity + Postgres + Storage + RLS (ADR-004 F-B1) ──
SUPABASE_URL=                      # https://<ref>.supabase.co   (local: http://localhost:54321)
SUPABASE_ANON_KEY=                 # client (Expo) key — safe to ship, RLS-guarded
SUPABASE_SERVICE_ROLE_KEY=         # NestJS server ONLY — bypasses RLS — NEVER ship to client
SUPABASE_JWT_ISSUER=               # for NestJS JWKS verification of Supabase access tokens
SUPABASE_JWKS_URL=                 # <SUPABASE_URL>/auth/v1/.well-known/jwks.json
DATABASE_URL=                      # pooled (Supavisor/PgBouncer) Postgres connection for NestJS

# ── WhatsApp / SMS OTP (pluggable OtpSender; mock needs none) (ADR-004 F-C1) ──
OTP_PROVIDER=mock                  # mock | meta_whatsapp | twilio | 360dialog
OTP_DEV_CODE=000000                # dev-only universal verify code (mock mode)
# meta_whatsapp:
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_OTP_TEMPLATE_NAME=        # pre-approved WhatsApp authentication template
# twilio (also the SMS fallback for the Meta path):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# ── Stripe billing — $1/month subscription (mockable BillingProvider; mock needs none) (ADR-004 F-D1) ──
BILLING_PROVIDER=mock              # mock | stripe
BILLING_DEV_GRANT=false            # mock only: true→always premium, false→always freemium
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=            # client (Expo) checkout
STRIPE_WEBHOOK_SECRET=             # verify webhook signatures
STRIPE_PRICE_ID=                   # the $1/month recurring price (USD)
STRIPE_SUCCESS_URL=                # checkout success deep link (default bestoffers://billing/success)
STRIPE_CANCEL_URL=                 # checkout cancel deep link  (default bestoffers://billing/cancel)
